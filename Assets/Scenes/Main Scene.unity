  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: Zaman Saati
  itemDescription: "Kronometre \xF6zelliklidir\nSa\u011F \xFCsteki ayar vidas\u0131
    ile kronometre \xE7al\u0131\u015F\u0131r ve  ikinci bas\u0131\u015Fta durur,
    \xFC\xE7\xFCnc\xFC bas\u0131\u015Fta ise ibreler 12 istikametinde s\u0131f\u0131rlan\u0131r.\nSol
    alttaki ayar d\xFC\u011Fmesi ile saat ayarlan\u0131r ve kurulur.\nSaatin arkas\u0131nda
    \xE7al\u0131\u015Fma h\u0131z\u0131n\u0131 ayarlayan yay ile \xE7al\u0131\u015Fan
    ayar d\xFC\u011Fmesi mevcuttur."
  isListText: 1
