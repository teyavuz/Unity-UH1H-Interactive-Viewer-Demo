  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: "Yak\u0131t Bas\u0131n\xE7 G\xF6stergesi"
  itemDescription: "28VAC bustan g\xFCc\xFCn\xFC al\u0131r. 1 amperlik FUEL PRESSURE
    IND sigortas\u0131 ile korunur.\nAna yak\u0131t hatt\u0131ndaki yak\u0131t\u0131n
    bas\u0131nc\u0131n\u0131 transmitter sayesinde psi cinsinden g\xF6sterir.\nYak\u0131t
    pompalar\u0131ndan biri elektrik di\u011Feri pn\xF6matik ise g\xF6stergedeki
    ye\u015Fil saha 5-35 psi, iki yak\u0131t pompas\u0131 da elektrikliyse 8-25psi
    olmal\u0131d\u0131r.\nYak\u0131t bas\u0131n\xE7 transmitter\u0131, motor \xF6n
    yang\u0131n duvar\u0131 ilerisinde, transmisyonun sa\u011F arkas\u0131ndad\u0131r.
    Ana yak\u0131t hatt\u0131ndaki bas\u0131n\xE7 de\u011Ferinin voltaj sinyallerini
    g\xF6stergeye iletir."
  isListText: 1
