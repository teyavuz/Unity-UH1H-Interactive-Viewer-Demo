  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: "Motor Ya\u011F Hararet G\xF6stergesi"
  itemDescription: "28VDC Essential bustan g\xFCc\xFCn\xFC al\u0131r.5 amperlik ENG&XMSN
    TEMP IND sigortas\u0131 taraf\u0131ndan korunur.\nElektrik rezistans tip motor
    ya\u011F hararet sens\xF6r\xFC sayesinde, harareti derece cinsinden g\xF6sterir\nMotor
    ya\u011F harareti, d\u0131\u015F hava s\u0131cakl\u0131\u011F\u0131 30\xB0C alt\u0131ndayken
    maksimum 93\xB0C,30\xB0C ve \xFCzerindeyken maksimum 100\xB0C olmal\u0131d\u0131r.\nMotor
    ya\u011F hararet sens\xF6r\xFC, motor ya\u011F pompas\u0131 muhafazas\u0131 i\xE7inde.
    Motor ya\u011F harareti voltaj sinyallerini g\xF6stergeye iletir."
  isListText: 1
