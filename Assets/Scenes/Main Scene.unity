--- !u!114 &723022773
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 723022770}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: "Radio Magnetic \u0130ndicators (RMI)"
  itemDescription: "Pilot ve copilot i\xE7in farkl\u0131 modellerde mevcuttur. \u0130kili
    ibreleri dairesel olarak, sabit referans i\u015Fareti alt\u0131nda hareket ederler.
    Gyromagnetic compass \nsisteminden ald\u0131klar\u0131 bilgi ile pusula ba\u015F\u0131n\u0131
    g\xF6sterirler.1 ve 2 numaral\u0131 ibrelerin ADF ve VOR setinden al\u0131nan
    bilgiyi g\xF6stermeleri i\xE7in se\xE7ilmesi gereklidir.\nADF(Automatic Direction
    Finder/Otmatik Y\xF6n Bulucu):Hava arac\u0131ndan bir radyo g\xF6ndermecine olan
    y\xF6n\xFC belirtmek i\xE7in kullan\u0131lan bir radyo almac\u0131d\u0131r.\u0130lk
    tasar\u0131m a\u015Famas\u0131nda kullan\u0131lan ticari radyolar\u0131n kapanmas\u0131
    veya frekans de\u011Fi\u015Ftirmesi ve yer de\u011Fi\u015Ftirmeleri s\xF6z konusu
    olunca baz\u0131 sabit noktalara yer istasyonlar\u0131 kurulmu\u015Ftur bu istasyonlara
    NDB(Non Directional Becon) ad\u0131 verilmektedir.\nVOR(VHF Omni-Directional
    Radio Range/\xC7ok Y\xFCksek Frekansl\u0131 Y\xF6nlendirilmi\u015F Yay\u0131n):
    VOR atmosferik parazitlerden etkilenmeyen istasyona do\u011Fru ve istasyondan
    ileriye do\u011Fru olmak \xFCzere kullanabilen 360 adet u\xE7u\u015F yolu sa\u011Flayan
    bir VHF seyr\xFCsefer kolayl\u0131\u011F\u0131d\u0131r.\n"
  isListText: 1
