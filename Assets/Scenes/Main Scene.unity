--- !u!114 &1676219967
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1676219964}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: "Course \u0130ndikat\xF6r"
  itemDescription: "Helikopterin pozisyonunu, sinyal al\u0131nan istasyona g\xF6re
    g\xF6sterir.\nDikey i\u015Faret sa\u011Fa, sola ve rota \xFCzerindeki u\xE7u\u015F
    bilgilerini sa\u011Flar.\nYatay i\u015Faret gidilen istasyona g\xF6re al\xE7alma
    a\xE7\u0131s\u0131n\u0131 ve sinyal kuvvetini ifade eder.\nHer iki i\u015Farete
    ait g\xFC\xE7 OFF bayraklar\u0131 vard\u0131r. G\xFC\xE7 kesintiye u\u011Frarsa
    veya sinyal g\xFCvenilmez seviyede olursa g\xF6r\xFCn\xFCrler. Normal \xE7al\u0131\u015Fma
    \u015Fartlar\u0131nda g\xF6r\xFCnmezler."
  isListText: 1
