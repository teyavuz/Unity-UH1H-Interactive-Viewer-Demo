  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: "Tork Bas\u0131n\xE7 G\xF6stergesi"
  itemDescription: "28VAC bustan g\xFCc\xFCn\xFC al\u0131r.1 amperlik TORQUR PRESSURE
    IND sigortas\u0131 ile korunur.\n\u0130ki yerden bilgi al\u0131r .Hareketli plakay\u0131
    bir miktar hareket ettiren hava bas\u0131nc\u0131 ve torkmetre ya\u011F bas\u0131nc\u0131n\u0131n
    bilgisini al\u0131r  . Transmitter bilgilerin fark\u0131n\u0131 al\u0131r ve
    g\xF6stergeye iletir .\nTransmitter a ba\u011Fl\u0131 2 adet hortum vard\u0131r.
    Bunlardan uzun olan\u0131 hava bas\u0131nc\u0131 bilgisini , k\u0131sa olan ise
    ya\u011F bas\u0131nc\u0131 bilgisini iletir.\nMotor \xE7\u0131k\u0131\u015F \u015Faft\u0131
    tork bas\u0131nc\u0131n\u0131 transmitter sayesinde psi cinsinden g\xF6sterir.\nTork
    bas\u0131n\xE7 transmitter\u0131 motorun sa\u011F taraf\u0131nda braket \xFCzerine
    montelidir. Motor \xE7\u0131k\u0131\u015F \u015Faft\u0131 tork bas\u0131nc\u0131n\u0131
    voltaj sinyallerini g\xF6stergeye iletir."
  isListText: 1
