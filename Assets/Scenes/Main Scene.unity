  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: Barometrik Altimetre
  itemDescription: "G\xF6sterge panelinde 2 adettir. Helikopterin deniz seviyesine
    olan irtifas\u0131n\u0131 feet cinsinden g\xF6sterir. \nStandart pitot statik
    g\xF6stergesidir.\nAtmosferik bas\u0131nc\u0131 alg\u0131lamas\u0131 i\xE7in
    statik bas\u0131n\xE7 portlar\u0131na irtibatl\u0131d\u0131r.\n\xDCzerindeki
    ayar d\xFC\u011Fmesi ile g\xF6sterge ibrelerinin atmosferik bas\u0131nca g\xF6re
    d\xFCzeltmesi yap\u0131l\u0131r."
  isListText: 1
