MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1070615430}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: "Yak\u0131t Miktar G\xF6sterge Sistemi"
  itemDescription: "Yak\u0131t miktar g\xF6stergesi ve 3 adet yak\u0131t miktar transmitterinden
    olu\u015Fur\n115VAC bustan beslenir, 1 amperlik FUEL QTY sigortasi ile korunur.
    \nG\xF6stergeyi test etmek i\xE7in yan\u0131nda bulunan FUEL QUANTITY TEST SWITCH'e
    bas\u0131l\u0131r , ibre s\u0131f\u0131ra do\u011Fru gider, b\u0131rak\u0131ld\u0131\u011F\u0131nda
    yak\u0131t miktar\u0131n\u0131 g\xF6sterir. \nYak\u0131t miktar transmitterlar\u0131
    2 adet sa\u011F \xF6n depoda, 1 adet merkez depoda olmak \xFCzere 3 adettir.
    Yak\u0131t miktar\u0131 alg\u0131lan\u0131r ve ortalamas\u0131 g\xF6stergeye
    iletilir."
  isListText: 1
