  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4cc07b05bfbfa49cd8a511b7a3233be5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemTitle: "Motor Ya\u011F Bas\u0131n\xE7 G\xF6stergesi"
  itemDescription: "28V AC Bustan g\xFCc\xFCn\xFC al\u0131r, 1 amperlik motor ya\u011F
    bas\u0131n\xE7 sigortas\u0131 taraf\u0131ndan korunur.\nMotor ya\u011F bas\u0131n\xE7
    transmitteri sayesinde bas\u0131nc\u0131 psi cinsinden g\xF6sterir. R\xF6lantide
    minimum 25 psi, devaml\u0131 80-100 psi maksimum 100 psi olmal\u0131d\u0131r.\nMotor
    ya\u011F bas\u0131n\xE7 transmitteri, motor giri\u015F k\u0131sm\u0131n\u0131n
    \xFCst noktas\u0131nda saat 12 istikametindedir.\nBas\u0131n\xE7 de\u011Ferini
    voltaj sinyalleri ile g\xF6stergeye iletir."
  isListText: 1
